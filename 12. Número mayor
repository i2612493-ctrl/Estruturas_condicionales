#12. Identificación de Número Mayor y Menor
def determinar_extremos():
    print('--- Comparador de 3 Números ---')
    numeros = []
    
    # 1. Entrada de datos
    for i in range(1, 4):
        while True:
            try:
                num = float(input(f'Ingrese el número {i}: '))
                numeros.append(num)
                break
            except ValueError:
                print('Error: Ingrese un valor numérico válido.')

    # 2. Proceso usando funciones integradas
    mayor = max(numeros)
    menor = min(numeros)

    # 3. Salida de resultados
    print(f'\n--- Resultados ---')
    print(f'Números ingresados: {numeros}')
    print(f'El número MAYOR es: {mayor}')
    print(f'El número MENOR es: {menor}')

determinar_extremos()
