# 17. Cálculo de Pago por Llamada Telefónica
def calcular_pago_llamada():
    print('--- Sistema de Facturación de Llamadas ---')

    # 1. Entrada de datos
    while True:
        try:
            tiempo = int(input('Ingrese la duración de la llamada (minutos): '))
            if tiempo > 0: break
            print('Error: La duración debe ser mayor a 0.')
        except ValueError: print('Error: Ingrese un número entero.')

    # Cambio: Ahora acepta 'si' o 'no'
    es_domingo = input('¿Es domingo? (si/no): ').strip().lower() == 'si'
    
    turno_noche = False
    if es_domingo:
        turno_noche = input('¿Es turno nocturno? (si/no): ').strip().lower() == 'si'

    # 2. Proceso: Cálculo del costo base por tramos
    costo_base = 0
    for m in range(1, tiempo + 1):
        if m <= 5:
            costo_base += 1.00
        elif m <= 8:
            costo_base += 0.80
        elif m <= 10:
            costo_base += 0.70
        else:
            costo_base += 0.50

    # 3. Cálculo de Impuestos
    tasa_impuesto = 0
    if es_domingo:
        tasa_impuesto = 0.05 if turno_noche else 0.03

    monto_impuesto = costo_base * tasa_impuesto
    total_pagar = costo_base + monto_impuesto

    # 4. Salida de resultados
    print(f'\n--- Detalle del Cobro ---')
    print(f'Duración: {tiempo} minutos')
    print(f'Costo Base: S/ {costo_base:.2f}')
    if es_domingo:
        tipo_dia = 'Domingo (Noche)' if turno_noche else 'Domingo (Día)'
        print(f'Impuesto ({tipo_dia}): S/ {monto_impuesto:.2f} ({tasa_impuesto*100:.0f}%)')
    else:
        print('Impuesto: S/ 0.00 (Día laborable)')
    print(f'-------------------------------')
    print(f'TOTAL A PAGAR: S/ {total_pagar:.2f}')

# Ejecutar la función
calcular_pago_llamada()
